# Copy to .env and fill in your own values. .env is gitignored — never commit real secrets.
# cp .env.example .env  && edit

# Weights & Biases API key — get yours at https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Optional: default W&B project / entity for runs
# WANDB_PROJECT=wm-manip
# WANDB_ENTITY=your_wandb_username
